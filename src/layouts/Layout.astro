---
const { title = "Rusty Notebooks" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #111111;
        --bg-soft: #1a1a1a;
        --text: #f2efe8;
        --muted: #b7aea3;
        --accent: #c47a3a;
        --border: #2b2b2b;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Georgia, "Times New Roman", serif;
        line-height: 1.6;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 48px 20px 80px;
      }

      .eyebrow {
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.8rem;
        margin-bottom: 12px;
      }

      h1, h2, h3 {
        line-height: 1.2;
        margin-top: 0;
      }

      h1 {
        font-size: 3rem;
        margin-bottom: 16px;
      }

      h2 {
        font-size: 1.6rem;
        margin-bottom: 16px;
      }

      p {
        margin: 0 0 16px;
        color: var(--text);
      }

      .muted {
        color: var(--muted);
      }

      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
      }

      .card {
        display: block;
        padding: 20px;
        background: var(--bg-soft);
        border: 1px solid var(--border);
        border-radius: 14px;
        transition: transform 0.15s ease, border-color 0.15s ease;
      }

      .card:hover {
        transform: translateY(-2px);
        border-color: var(--accent);
        text-decoration: none;
      }

      .card-title {
        font-size: 1.15rem;
        margin-bottom: 8px;
        color: var(--text);
      }

      .section {
        margin-top: 40px;
      }
      .platform-button {
  display: flex;
  align-items: center;
  gap: 14px;

  padding: 14px 20px;
  border-radius: 999px;

  font-weight: 600;
  font-size: 1rem;

  text-decoration: none;

  background: #e7e3dc;
  color: #111;

  transition: all 0.2s ease;
}

.platform-button:hover {
  transform: translateY(-2px);
  opacity: 0.9;
}

/* YouTube spezifisch */
.platform-button.youtube svg {
  color: #ff0000;   /* 👈 DAS macht das Icon rot */
  background: none; /* 👈 entfernt roten Kasten */
  padding: 0;

}
.platform-button.youtube {
  background: #f2d6d6;
  text-decoration: none;
  color: #111;
}

/* Spotify spezifisch */
.platform-button.spotify {
  background: #1DB954;
  text-decoration: none;
  color: #111;
}
.platform-button.spotify svg {
  background: none;
  padding: 0;
}

/* Background image */
.chapter-bg {
  position: relative;
  min-height: 100vh;
  isolation: isolate;
}

.chapter-bg::before {
  content: "";
  position: fixed;
  inset: 0;

  background:
    linear-gradient(rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.85)),
    var(--bg-image, url("/images/chapter1.png")) center/cover no-repeat;

  z-index: -1;
}

.chapter-content {
  position: relative;
  z-index: 1;
}

/* Back Button style */
.back-button {
  display: inline-flex;
  align-items: center;
  gap: 10px;

  padding: 10px 16px;
  border-radius: 999px;
  margin-top: 20px;
  margin-bottom: 20px;

  background: rgba(255,255,255,0.08);
  color: var(--text);

  border: 1px solid var(--border);

  text-decoration: none;
  font-size: 0.95rem;

  transition: all 0.2s ease;
}

.back-button:hover {
  background: rgba(255,255,255,0.15);
  transform: translateX(-3px);
  text-decoration: none;
  color: var(--accent);
  border-color: var(--accent);
}

/* Hero */
.eyebrow-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;

  padding: 6px 12px;
  margin-bottom: 14px;
  border-radius: 999px;

  border: 1px solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.04);

  color: var(--muted);
  text-decoration: none;

  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;

  transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
}

.eyebrow-pill:hover {
  color: var(--text);
  border-color: rgba(255, 255, 255, 0.24);
  background-color: rgba(255, 255, 255, 0.08);
  text-decoration: none;
}

.eyebrow-pill-arrow {
  font-size: 0.8rem;
  line-height: 1;
  transition: transform 0.2s ease;
}

.eyebrow-pill:hover .eyebrow-pill-arrow {
  transform: translateX(-2px);
}

.eyebrow-pill-label {
  line-height: 1;
}

.hero p {
  font-style: italic;
  opacity: 0.9;
}

h1 {
  font-size: 3.6rem;
}
/* VisualizerSection */
.video-frame {
  position: relative;
  padding-top: 56.25%;
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
  background: #000;
}

.video-iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
}

/* Listen Section */
.listen-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

/* Tracklist Section */
.track-list {
  display: flex;
  flex-direction: column;
  gap: 0;
    background: rgba(255,255,255,0.02);
    padding-left: 8px;
  border-radius: 12px;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.track-row {
  display: grid;
  grid-template-columns: 42px 1fr auto;
  align-items: center;
  gap: 18px;

  padding: 18px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  background-color: transparent;

  text-decoration: none;
  transition: background-color 0.2s ease, padding-left 0.2s ease;
}

.track-row:hover {
  background-color: rgba(255, 255, 255, 0.03);
  padding-left: 8px;
  text-decoration: none;
}

.track-number {
  display: block;
  color: var(--muted);
  font-size: 0.8rem;
  letter-spacing: 0.12em;
}

.track-copy {
  min-width: 0;
}

.track-copy p {
  margin: 4px 0 0;
}

.track-title {
  color: var(--text);
  font-size: 1.15rem;
  font-weight: 600;
}


/* Narrative Section */
.section-narrative {
  margin-top: px;
}

.narrative {
  max-width: 640px;
}

.narrative p {
  color: var(--muted);
  margin-bottom: 18px;
}

.narrative-final {
  margin-top: 32px;
  color: var(--text);
  font-style: italic;
  font-size: 1.05rem;
}

/* ChaperList Section */
.chapter-list {
  display: flex;
  flex-direction: column;
  gap: 0;

  background: rgba(255, 255, 255, 0.02); /* 👈 DAS ist der Effekt */
  border-radius: 12px;

  border-top: 1px solid rgba(255, 255, 255, 0.08);
  padding-left: 8px; /* 👈 leicht eingerückt wie Tracklist */
}

.chapter-row {
  display: grid;
  grid-template-columns: 80px 1fr;  
  align-items: center;
  gap: 16px;

  padding: 16px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);

  background: transparent;
  text-decoration: none;

  transition: background-color 0.2s ease, padding-left 0.2s ease;
}

.chapter-row:hover {
  background-color: rgba(255, 255, 255, 0.03);
  text-decoration: none;
  padding-left: 8px;
}

.chapter-thumb {
  width: 80px;
  aspect-ratio: 1 / 1;
  border-radius: 8px;
  overflow: hidden;
  opacity: 0.9;
}

.chapter-row:hover .chapter-thumb {
  opacity: 1;
}

.chapter-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.chapter-copy {
  min-width: 0;
}

.chapter-row-title {
  color: var(--text);
  font-size: 1.08rem;
  font-weight: 600;
}

.chapter-copy p {
  margin: 4px 0 0;
}
    </style>
  </head>
  <body>
    <main class="container">
      <slot />
    </main>
  </body>
</html>


