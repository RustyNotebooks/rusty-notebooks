---
const { href, label = "Rusty Notebooks" } = Astro.props;
---

<header class="sticky-header">
  <div class="header-alignment-wrapper">
    <a href={href} class="eyebrow-pill">
      <span class="eyebrow-pill-arrow">←</span>
      <span class="eyebrow-pill-label">{label}</span>
    </a>
  </div>
</header>

<script is:inline>
  function updateHeader() {
    const header = document.querySelector('.sticky-header');
    if (!header) return;

    if (window.scrollY > 30) {
      header.classList.add('is-scrolled');
    } else {
      header.classList.remove('is-scrolled');
    }
  }

  // Astro-Event-Listener für Navigationen (mit View Transitions)
  document.addEventListener('astro:page-load', () => {
    updateHeader(); // Zustand beim Laden der Seite prüfen
    
    window.removeEventListener('scroll', updateHeader); // Saubermachen
    window.addEventListener('scroll', updateHeader);    // Neu binden
  });
</script>