---
import Layout from "../../../layouts/Layout.astro";
import Hero from "../../../components/Hero.astro";
import VisualizerSection from "../../../components/VisualizerSection.astro";
import NotebookSection from "../../../components/NotebookSection.astro";
import ListenSection from "../../../components/ListenSection.astro";
---

<Layout title="The Cedar and the Stone — Rusty Notebooks">
<div class="chapter-bg" style="--bg-image: url('/images/thecedarandthestone.png');">
<div class="chapter-content container">
  <Hero eyebrow="Chapter I — Resonance of Rust"
        title="The Cedar and the Stone"
        backHref={"/chapters/chapter1"}/>

  <VisualizerSection
    title="Official Visualizer"
    youtubeId="uI3x3vrQ2aI"/>

  <NotebookSection title="From Rusty’s notebook">
<div class="narrative">
  <p>
    Some journeys don’t end with a finish line.<br />
    They end with a place to rest.
  </p>

  <p>
    “The Cedar and the Stone” lives in the quiet moment when the road finally slows —<br />
    a wooden house standing steady against the wind,<br />
    a warm kitchen light in the evening,<br />
    and the realization<br />
    that the longest journeys<br />
    often lead us back to something simple.
  </p>

  <p>
    It’s a song about roots —<br />
    about weathered wood,<br />
    patient stone,<br />
    and the quiet promise of staying.
  </p>

  <p class="narrative-final">
    Sometimes the strongest shelter<br />
    is the one we build together.
  </p>
</div>
  </NotebookSection>

<ListenSection
  links={[
    {
      href: "https://www.youtube.com/watch?v=uI3x3vrQ2aI",
      label: "YouTube",
      type: "youtube"
    },
    {
      href: "https://open.spotify.com/intl-de/track/0C8VfDH3Z8Z3WFvyBToiLv?si=69f587711f2e4d7c",
      label: "Spotify",
      type: "spotify"
    }
    /* Comming soon 
    ,
    {
      href: "https://music.apple.com/us/album/burn-cedarwood/1877571983?i=1877571984",
      label: "Apple Music",
      type: "applemusic"
    }
      */
  ]}
/>

    </div> <!-- chapter-content -->
</div> <!-- chapter-bg -->
</Layout>