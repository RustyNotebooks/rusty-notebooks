---
import Layout from "../../../layouts/Layout.astro";
import BackButton from "../../../components/BackButton.astro";
import Hero from "../../../components/Hero.astro";
import VisualizerSection from "../../../components/VisualizerSection.astro";
import NotebookSection from "../../../components/NotebookSection.astro";
import ListenSection from "../../../components/ListenSection.astro";
---

<Layout title="Static on the Radio — Rusty Notebooks">
<div class="chapter-bg" style="--bg-image: url('/images/staticontheradio.png');">
<div class="chapter-content">
  <Hero eyebrow="Chapter I — Resonance of Rust"
        title="Static on the Radio"
        backHref={"/chapters/chapter1"}/>

  <VisualizerSection
    title="Official Visualizer"
    youtubeId="01X9MLpyYFc"/>

  <NotebookSection title="From Rusty’s notebook">
<div class="narrative">
  <p>
    Some signals don’t need to be perfect<br />
    to be real.
  </p>

  <p>
    “Static on the Radio” lives in those imperfect moments —<br />
    the quiet crackle of an old station,<br />
    fading memories,<br />
    and the space between who we were<br />
    and who we’re becoming.
  </p>

  <p class="narrative-final">
    Sometimes the signal is weak…<br />
    but the soul still comes through.
  </p>
</div>
  </NotebookSection>

<ListenSection
  links={[
    {
      href: "https://www.youtube.com/watch?v=01X9MLpyYFc",
      label: "YouTube",
      type: "youtube"
    },
    {
      href: "https://open.spotify.com/intl-de/track/0kLkI60wnizjpYaQGUC2SE?si=df1c5e77112c47e0",
      label: "Spotify",
      type: "spotify"
    }
  ]}
/>

<BackButton 
  href="/chapters/chapter1" 
  label="Resonance of Rust" 
/>

    </div> <!-- chapter-content -->
</div> <!-- chapter-bg -->
</Layout>