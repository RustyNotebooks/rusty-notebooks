---
import Layout from "../../../layouts/Layout.astro";
import BackButton from "../../../components/BackButton.astro";
import Hero from "../../../components/Hero.astro";
import VisualizerSection from "../../../components/VisualizerSection.astro";
import NotebookSection from "../../../components/NotebookSection.astro";
import ListenSection from "../../../components/ListenSection.astro";
---

<Layout title="Burn & Cedarwood — Rusty Notebooks">
<div class="chapter-bg" style="--bg-image: url('/images/burnandcedarwood.png');">
<div class="chapter-content container">
  <Hero eyebrow="Chapter I — Resonance of Rust"
        title="Burn & Cedarwood"
        backHref={"/chapters/chapter1"}/>

  <VisualizerSection
    title="Official Visualizer"
    youtubeId="reBUbEqAsxs"/>

  <NotebookSection title="From Rusty’s notebook">
    <div class="narrative">
    <p>
      A quiet porch.<br />
      A slow fire glowing in the dark.<br />
      And the kind of night where time finally stops rushing.
    </p>

    <p>
      This song is about stillness — about letting the evening settle in and
      finding warmth in the small moments that don’t ask for anything.
    </p>

    <p class="narrative-final">
      Take a breath. Lean back.<br />
      Let the cedarwood burn slow.
    </p>
  </div>
  </NotebookSection>

<ListenSection
  links={[
    {
      href: "https://www.youtube.com/watch?v=reBUbEqAsxs",
      label: "YouTube",
      type: "youtube"
    },
    {
      href: "https://open.spotify.com/track/537jkf4rmG2Vg5fryfzUeu",
      label: "Spotify",
      type: "spotify"
    },
    {
      href: "https://music.apple.com/us/album/burn-cedarwood/1877571983?i=1877571984",
      label: "Apple Music",
      type: "applemusic"
    }
  ]}
/>

    </div> <!-- chapter-content -->
</div> <!-- chapter-bg -->
</Layout>