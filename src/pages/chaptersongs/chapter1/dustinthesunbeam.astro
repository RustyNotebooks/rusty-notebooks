---
import Layout from "../../../layouts/Layout.astro";
import Hero from "../../../components/Hero.astro";
import VisualizerSection from "../../../components/VisualizerSection.astro";
import NotebookSection from "../../../components/NotebookSection.astro";
import ListenSection from "../../../components/ListenSection.astro";
import Footer from "../../../components/Footer.astro";
---

<Layout title="Dust in the Sunbeam — Rusty Notebooks">
    <div
        class="chapter-bg"
        style="--bg-image: url('/images/dustinthesunbeam.png');"
    >
        <div class="chapter-content container">
            <Hero
                eyebrow="Chapter I — Resonance of Rust"
                title="Dust in the Sunbeam"
                backHref={"/chapters/chapter1"}
            />

            <VisualizerSection
                title="Official Visualizer"
                youtubeId="_-lOmRKUf5A"
            />

            <NotebookSection title="From Rusty’s notebook">
                <div class="narrative">
                    <p>
                        Some moments don’t arrive with thunder.<br />
                        They arrive quietly —<br />
                        in a beam of light through an old window.
                    </p>

                    <p>
                        “Dust in the Sunbeam” lives in that still afternoon
                        moment —<br />
                        dust floating in the air,<br />
                        the kettle humming in the kitchen,<br />
                        and the quiet realization<br />
                        that life has already given us more<br />
                        than we once knew how to hold.
                    </p>

                    <p>
                        It’s a song about memory —<br />
                        about time moving slowly through old rooms,<br />
                        and the small pieces of the past<br />
                        that still hold up the present.
                    </p>

                    <p class="narrative-final">
                        Sometimes the simplest light<br />
                        shows us everything we need to see.
                    </p>
                </div>
            </NotebookSection>

            <ListenSection
                links={[
                    {
                        href: "https://www.youtube.com/watch?v=_-lOmRKUf5A",
                        label: "YouTube",
                        type: "youtube",
                    },
                    {
                        href: "https://open.spotify.com/intl-de/track/2vFC7nsAaM1CxoQNDyiqdf?si=b011c41770414b79",
                        label: "Spotify",
                        type: "spotify",
                    },
                    /* Comming soon 
    ,
    {
      href: "https://music.apple.com/us/album/burn-cedarwood/1877571983?i=1877571984",
      label: "Apple Music",
      type: "applemusic"
    }
      */
                ]}
            />
            <Footer />
        </div>
        <!-- chapter-content -->
    </div>
    <!-- chapter-bg -->
</Layout>
