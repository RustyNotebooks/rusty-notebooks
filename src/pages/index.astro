---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Rusty Notebooks">
  <section class="hero">
    <div class="eyebrow">Americana Storytelling in Songs</div>
    <h1>Rusty Notebooks</h1>
    <p>
      A story told in songs. Every chapter follows Rusty through a different
      phase of his life.
    </p>
    <p class="muted">
      Start with the first chapter.
    </p>
  </section>

  <section class="section">
    <h2>Chapter</h2>

    <div class="card-grid">
      <a class="card" href="/chapters/chapter1">
        <div class="card-title">Chapter 1 — Quiet Morning</div>
        <p class="muted">
          Rusty wakes up in a small town before the world starts moving.
        </p>
      </a>
    </div>
  </section>
</Layout>
