---
import Layout from "../../../layouts/Layout.astro";
import Hero from "../../../components/Hero.astro";
import VisualizerSection from "../../../components/VisualizerSection.astro";
import NotebookSection from "../../../components/NotebookSection.astro";
import ListenSection from "../../../components/ListenSection.astro";
import Footer from "../../../components/Footer.astro";

// Daten importieren
import { chapters } from "../../../data/chapters";
import * as allAlbums from "../../../data/albums";
import TrackNavigation from "../../../components/TrackNavigation.astro";
import StickyHeader from "../../../components/StickyHeader.astro";

export async function getStaticPaths() {
  // ... dein getStaticPaths Code bleibt identisch ...
  const paths = [];
  for (const chapter of chapters) {
    const albumKey = `${chapter.id}Songs` as keyof typeof allAlbums;
    const songs = allAlbums[albumKey] || [];
    for (let i = 0; i < songs.length; i++) {
      paths.push({
        params: { chapter: chapter.id, track: songs[i].id },
        props: {
          chapter,
          song: songs[i],
          prevSong: songs[i - 1] || null,
          nextSong: songs[i + 1] || null,
        },
      });
    }
  }
  return paths;
}

const { chapter, song, prevSong, nextSong } = Astro.props;

// --- HIER IST DIE LOGIK FÜR DIE NUMMERIERUNG ---
const songs = allAlbums[
  `${chapter.id}Songs` as keyof typeof allAlbums
] as any[];
const trackIndex = songs.findIndex((s) => s.id === song.id);
const trackNumber = trackIndex + 1;
const songTitle = song.title;
const heroInfo = `Track ${trackNumber}`;
---

<Layout title={`${song.title}`}>
  <StickyHeader href={`/${chapter.id}`} label={chapter.title} />
  <div class="chapter-bg" style={`--bg-image: url('${song.image}');`}>
    <div class="chapter-content container">
      <Hero
        title={songTitle}
        heroInfo={heroInfo}
      />

      <VisualizerSection
        title="Official Visualizer"
        youtubeId={song.youtubeId}
      />
      <ListenSection links={song.links} />
      <NotebookSection title="From Rusty’s notebook">
        <div class="narrative" set:html={song.notebookHtml} />
      </NotebookSection>

      <TrackNavigation
        chapter={chapter}
        prevSong={prevSong}
        nextSong={nextSong}
        allAlbums={allAlbums}
      />

      <Footer />
    </div>
  </div>
</Layout>
