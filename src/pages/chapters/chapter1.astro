---
import Layout from "../../layouts/Layout.astro";
import BackButton from "../../components/BackButton.astro";
import Hero from "../../components/Hero.astro";
import TrackListSection from "../../components/TrackListSection.astro";
---

<Layout title="Chapter 1">

<div class="chapter-bg" style="--bg-image: url('/images/template.png');">
<div class="chapter-content">
  <Hero eyebrow="Chapter 1"
        title="Resonance of Rust"
        backHref="/"/>

<section class="section section-narrative">
  <div class="narrative">
    <p>
      Somewhere between crackling wood, quiet voices, and the silence in between,
      Resonance of Rust creates a sound that feels less like music — and more like a place.
    </p>

    <p>
      Blending acoustic chill-country, lo-fi folk, and raw Americana, the songs move slowly
      and deliberately. No big climaxes — just honest, intimate moments that are allowed to breathe.
    </p>

    <p>
      The music circles around time, memory, and coming home — not as a straight line,
      but as a loop that could be a beginning or an ending.
    </p>

    <p class="narrative-final">
      What remains is a feeling:<br />
      You’re exactly where you’re supposed to be.
    </p>
  </div>
</section>

 <TrackListSection
  title="Songs"
  songs={[
    {
      number: "01",
      title: "Burn & Cedarwood",
      href: "/chaptersongs/chapter1/burnandcedarwood"
    },
    {
      number: "02",
      title: "Blue Smoke & Steam",
      href: "/chaptersongs/chapter1/bluesmokeandsteam"
    },
    {
      number: "03",
      title: "Static on the Radio",
      href: "/chaptersongs/chapter1/staticontheradio"
    }
  ]}
/>

  </div> <!-- chapter-content -->
</div> <!-- chapter-bg -->
</Layout>