---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Chapter 1">

<div class="chapter-bg" style="--bg-image: url('/images/template.png');">
<div class="chapter-content">
  <section class="hero">
    <div class="eyebrow">Chapter 1</div>
    <h1>Resonance of Rust</h1>
    <p>
      Rusty wakes up before the sun rises. The town is quiet,
      the air still. Nothing has happened yet — but something is about to change.
    </p>
  </section>

  <section class="section">
    <h2>Songs</h2>

    <div class="card-grid">
      <a class="card" href="/songs/quiet-morning">
        <div class="card-title">Burn & Cedarwood</div>
        <p class="muted">
          The first thoughts before the world wakes up.
        </p>
      </a>
    </div>
  </section>

  <p style="margin-top:40px;">
    <a href="/">← Back to Home</a>
  </p>
  </div> <!-- chapter-content -->
</div> <!-- chapter-bg -->
</Layout>